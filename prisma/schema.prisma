// CANONICAL: Single Prisma schema for zentrix.
// Reference: docs/LESSONS_FROM_WAGER.md R1 (one schema), R4 (BigInt money),
//            R5 (idempotency on DB), R6 (FOR UPDATE in app code).
//
// DO NOT create parallel files like *-additions.prisma or schema-v2.prisma.
// Every change to the data model goes through this file via `prisma migrate dev`.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── ENUMS ──────────────────────────────────────────────────────────────────

enum AccountType {
  USER
  BET_ESCROW
  TREASURY
  EXTERNAL
}

enum LedgerEntryType {
  DEPOSIT_CREDIT
  WITHDRAWAL_DEBIT
  WITHDRAWAL_REVERSAL
  ESCROW_LOCK
  ESCROW_RELEASE
  SETTLEMENT_PAYOUT
  FEE_COLLECTION
  ADMIN_ADJUSTMENT
  BET_PLACEMENT
  BET_REFUND
}

enum DepositStatus {
  PENDING
  CREDITED
  FAILED
}

enum WithdrawalStatus {
  PENDING_VALIDATION
  QUEUED
  SUBMITTED
  CONFIRMED
  FAILED
  CANCELLED
}

// ── ENUMS: BET / POOL / DISPUTE (P08, ADR-0003) ────────────────────────────

enum BetStatus {
  DRAFT
  PENDING_ESCROW
  OPEN
  ACTIVE
  RESULT_PROPOSED
  AWAITING_CONFIRMATION
  DISPUTED
  SETTLED
  CANCELLED
  EXPIRED
  VOID
}

enum SettlementMode {
  PROOF_CONFIRM
  // ARBITER_REQUIRED, AUTO_VERIFY post-MVP — separate ADR
}

enum SettlementType {
  BINARY // A wins or B wins
  THRESHOLD // Above or below value
}

enum SettlementMethod {
  OFFICIAL_RESULT
  ORACLE_VALUE
  PLATFORM_PROOF
  THRESHOLD_METRIC
}

enum ResultStatus {
  PENDING
  PROPOSED
  CONFIRMED
  DISPUTED
  OVERRIDDEN
}

enum MatchStatus {
  SCHEDULED
  RESULT_SUBMITTED
  SETTLED
  DISPUTED
}

enum PoolStatus {
  DRAFT
  OPEN
  CLOSED
  SETTLED
  CANCELLED
}

enum DisputeStatus {
  OPEN
  EVIDENCE_PHASE
  ADMIN_REVIEW
  RESOLVED
}

enum DisputeOutcome {
  CREATOR_WINS
  OPPONENT_WINS
  VOID
}

enum ReputationTier {
  NORMAL
  RESTRICTED
  FLAGGED
}

enum EvidenceType {
  TEXT
  URL
  IMAGE
  VIDEO
}

enum TournamentFormat {
  SIMPLE
  SINGLE_ELIM
  DOUBLE_ELIM
}

enum BracketSide {
  WINNERS
  LOSERS
  FINAL
}

enum ConfirmationDecision {
  CONFIRM_WINNER
  DISAGREE
}

enum LedgerSettlementStatus {
  NOT_REQUIRED
  PENDING
  PROCESSING
  FINALIZED
  FAILED
  FAILED_TERMINAL
}

enum OnChainPayoutStatus {
  PENDING
  SUBMITTED
  CONFIRMED
  FAILED
  FAILED_TERMINAL
}

enum EscrowDepositStatus {
  PENDING_CREATOR
  PENDING_OPPONENT
  LOCKED
  FAILED
  FAILED_TERMINAL
}

// ── MODELS ─────────────────────────────────────────────────────────────────

model User {
  id                    String    @id @default(uuid())
  privyId               String    @unique @map("privy_id")
  email                 String?   @unique
  embeddedWalletAddress String?   @unique @map("embedded_wallet_address")
  walletDelegatedAt     DateTime? @map("wallet_delegated_at")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  financialAccount FinancialAccount? @relation("UserFinancialAccount")
  deposits         Deposit[]
  withdrawals      Withdrawal[]

  // Bet relations (P08)
  betsCreated                  Bet[]                        @relation("BetCreator")
  betsOpponent                 Bet[]                        @relation("BetOpponent")
  betsWon                      Bet[]                        @relation("BetWinner")
  betParticipants              BetParticipant[]
  betInvitesUsed               BetInvite[]
  betEvidence                  BetEvidence[]
  betStateTransitions          BetStateTransition[]
  confirmations                BetParticipantConfirmation[] @relation("ConfirmationActor")
  confirmationsClaimedAsWinner BetParticipantConfirmation[] @relation("ConfirmationClaimedWinner")
  resultClaims                 BetResultClaim[]             @relation("ResultClaimActor")
  resultClaimsAsWinner         BetResultClaim[]             @relation("ResultClaimWinner")
  matchEvidence                MatchEvidence[]
  poolsCreated                 Pool[]                       @relation("PoolCreator")
  disputesOpened               Dispute[]                    @relation("DisputeOpener")
  disputesResolved             Dispute[]                    @relation("DisputeResolver")
  reputation                   UserReputation?
  reputationEvents             ReputationEvent[]
  idempotencyKeys              IdempotencyKey[]

  @@map("users")
}

model FinancialAccount {
  id           String      @id @default(uuid())
  accountType  AccountType @map("account_type")
  scopeKey     String      @unique @map("scope_key")
  userId       String?     @unique @map("user_id")
  balanceUnits  BigInt      @default(0) @map("balance_units")
  reservedUnits BigInt      @default(0) @map("reserved_units")
  label         String?
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  user          User?         @relation("UserFinancialAccount", fields: [userId], references: [id])
  creditEntries LedgerEntry[] @relation("CreditAccount")
  debitEntries  LedgerEntry[] @relation("DebitAccount")

  @@index([accountType], map: "idx_financial_accounts_type")
  @@index([balanceUnits], map: "idx_financial_accounts_balance")
  @@map("financial_accounts")
}

model LedgerTransaction {
  id              String   @id @default(uuid())
  idempotencyKey  String   @unique @map("idempotency_key")
  description     String
  initiatorUserId String?  @map("initiator_user_id")
  refType         String?  @map("ref_type")
  refId           String?  @map("ref_id")
  totalDebits     BigInt   @map("total_debits")
  totalCredits    BigInt   @map("total_credits")
  entryCount      Int      @map("entry_count")
  isBalanced      Boolean  @default(true) @map("is_balanced")
  createdAt       DateTime @default(now()) @map("created_at")

  entries LedgerEntry[]

  @@index([refType, refId], map: "idx_ledger_tx_ref")
  @@index([createdAt], map: "idx_ledger_tx_created")
  @@map("ledger_transactions")
}

model LedgerEntry {
  id                 String          @id @default(uuid())
  transactionId      String          @map("transaction_id")
  debitAccountId     String          @map("debit_account_id")
  creditAccountId    String          @map("credit_account_id")
  amountUnits        BigInt          @map("amount_units")
  entryType          LedgerEntryType @map("entry_type")
  debitBalanceAfter  BigInt          @map("debit_balance_after")
  creditBalanceAfter BigInt          @map("credit_balance_after")
  note               String?
  meta               Json?
  createdAt          DateTime        @default(now()) @map("created_at")

  transaction   LedgerTransaction @relation(fields: [transactionId], references: [id])
  debitAccount  FinancialAccount  @relation("DebitAccount", fields: [debitAccountId], references: [id])
  creditAccount FinancialAccount  @relation("CreditAccount", fields: [creditAccountId], references: [id])

  @@index([transactionId], map: "idx_ledger_entries_tx")
  @@index([debitAccountId, createdAt], map: "idx_ledger_entries_debit")
  @@index([creditAccountId, createdAt], map: "idx_ledger_entries_credit")
  @@index([entryType], map: "idx_ledger_entries_type")
  @@map("ledger_entries")
}

model Deposit {
  id          String        @id @default(uuid())
  userId      String        @map("user_id")
  txSignature String        @map("tx_signature")
  logIndex    Int           @default(0) @map("log_index")
  amountUnits BigInt        @map("amount_units")
  slot        BigInt
  status      DepositStatus @default(PENDING)
  ledgerTxId  String?       @map("ledger_tx_id")
  createdAt   DateTime      @default(now()) @map("created_at")
  creditedAt  DateTime?     @map("credited_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([txSignature, logIndex], map: "uq_deposits_tx_log")
  @@index([userId, createdAt], map: "idx_deposits_user_created")
  @@index([status], map: "idx_deposits_status")
  @@map("deposits")
}

model Withdrawal {
  id                 String           @id @default(uuid())
  userId             String           @map("user_id")
  toAddress          String           @map("to_address")
  amountUnits        BigInt           @map("amount_units")
  feeUnits           BigInt           @default(0) @map("fee_units")
  status             WithdrawalStatus @default(PENDING_VALIDATION)
  ledgerTxId         String?          @map("ledger_tx_id")
  reversalLedgerTxId String?          @map("reversal_ledger_tx_id")
  txSignature        String?          @map("tx_signature")
  failReason         String?          @map("fail_reason")
  version            Int              @default(0)
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")
  submittedAt        DateTime?        @map("submitted_at")
  confirmedAt        DateTime?        @map("confirmed_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt], map: "idx_withdrawals_user_created")
  @@index([status], map: "idx_withdrawals_status")
  @@map("withdrawals")
}

model IdempotencyKey {
  // Bestaand (P05/P06 backward-compat — nooit verwijderen):
  key       String   @id
  scope     String
  createdAt DateTime @default(now()) @map("created_at")

  // Nieuw in P08 — allemaal nullable, alleen gebruikt door bet/dispute routes:
  userId       String?   @map("user_id")
  route        String?
  statusCode   Int?      @map("status_code")
  responseJson Json?     @map("response_json")
  completedAt  DateTime? @map("completed_at")
  expiresAt    DateTime? @map("expires_at")

  user User? @relation(fields: [userId], references: [id])

  @@unique([userId, key], map: "uq_idem_user_key")
  @@index([scope, createdAt], map: "idx_idem_scope_created")
  @@index([expiresAt], map: "idx_idem_expires")
  @@index([userId, route, createdAt], map: "idx_idem_user_route_created")
  @@map("idempotency_keys")
}

model ReconciliationLog {
  id                String   @id @default(uuid())
  checkedAt         DateTime @default(now()) @map("checked_at")
  ledgerTotalUnits  BigInt   @map("ledger_total_units")
  onChainTotalUnits BigInt?  @map("on_chain_total_units")
  delta             BigInt?
  notes             String?

  @@index([checkedAt], map: "idx_recon_checked_at")
  @@map("reconciliation_logs")
}

/// Per-feature operational kill switch. Distinct from the R8 hardcoded
/// fallback — that's a code-deploy switch for env-store outages. This is
/// the day-to-day operator lever (flip via admin route).
model CircuitBreaker {
  id         String    @id @default(uuid())
  /// Unique key, e.g. "withdrawals", "deposits", "settlement"
  key        String    @unique
  isOpen     Boolean   @default(false) @map("is_open")
  /// When opened, why and by whom
  reason     String?
  openedAt   DateTime? @map("opened_at")
  openedBy   String?   @map("opened_by")
  closedAt   DateTime? @map("closed_at")
  /// For automatic re-evaluation: trip count and last trip time
  tripCount  Int       @default(0) @map("trip_count")
  lastTripAt DateTime? @map("last_trip_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@map("circuit_breakers")
}

// ── PHASE 2: 1v1 P2P BETS + POOL CONTAINER (P08, ADR-0003) ─────────────────

model Bet {
  id             String  @id @default(uuid())
  createdById    String  @map("created_by_id")
  opponentUserId String? @map("opponent_user_id")
  creatorSide    String  @map("creator_side")
  acceptorSide   String? @map("acceptor_side")
  title          String  @default("")
  outcomeA       String  @default("") @map("outcome_a")
  outcomeB       String  @default("") @map("outcome_b")
  stakeUnits     BigInt  @map("stake_units")

  status         BetStatus      @default(DRAFT)
  settlementMode SettlementMode @default(PROOF_CONFIRM) @map("settlement_mode")
  resultStatus   ResultStatus   @default(PENDING) @map("result_status")
  winnerId       String?        @map("winner_id")

  version             Int       @default(0)
  expiresAt           DateTime  @map("expires_at")
  confirmDeadline     DateTime? @map("confirm_deadline")
  disputeWindowEndsAt DateTime? @map("dispute_window_ends_at")

  settledAt   DateTime? @map("settled_at")
  cancelledAt DateTime? @map("cancelled_at")
  voidedAt    DateTime? @map("voided_at")

  poolId  String? @map("pool_id")
  matchId String? @map("match_id")

  createdByLedgerTxId String? @map("created_by_ledger_tx_id")

  // P34: Template tracking (Wager pattern). No FK relation to BetTemplate —
  // BetTemplate is soft-deletable, so a hard FK would force cascade/restrict
  // behaviour we don't want. category is denormalized for fast marketplace
  // filtering without a join.
  templateId String? @map("template_id")
  category   String?
  isCustom   Boolean @default(false) @map("is_custom")

  // G.1: Ledger finalizer state machine (Wager pattern)
  ledgerStatus         LedgerSettlementStatus @default(NOT_REQUIRED) @map("ledger_status")
  ledgerOutcome        String?                @map("ledger_outcome")
  ledgerTargetWinnerId String?                @map("ledger_target_winner_id")
  ledgerFinalizedAt    DateTime?              @map("ledger_finalized_at")
  ledgerLastError      String?                @map("ledger_last_error")
  ledgerErrorCode      String?                @map("ledger_error_code")
  ledgerRetryCount     Int                    @default(0) @map("ledger_retry_count")
  ledgerNextRetryAt    DateTime?              @map("ledger_next_retry_at")
  ledgerProcessingAt   DateTime?              @map("ledger_processing_at")
  ledgerProcessingBy   String?                @map("ledger_processing_by")

  // H.4: On-chain payout tracking
  onChainPayoutStatus  OnChainPayoutStatus?   @map("on_chain_payout_status")
  payoutWinnerTxSig    String?                @map("payout_winner_tx_sig")
  payoutFeeTxSig       String?                @map("payout_fee_tx_sig")
  payoutAttemptedAt    DateTime?              @map("payout_attempted_at")
  payoutConfirmedAt    DateTime?              @map("payout_confirmed_at")
  payoutLastError      String?                @map("payout_last_error")
  payoutRetryCount     Int                    @default(0) @map("payout_retry_count")
  payoutNextRetryAt    DateTime?              @map("payout_next_retry_at")
  payoutProcessingAt   DateTime?              @map("payout_processing_at")
  payoutProcessingBy   String?                @map("payout_processing_by")

  // H.5b: Escrow deposit tracking (LOCK V2)
  escrowDepositStatus        EscrowDepositStatus?  @map("escrow_deposit_status")
  escrowDepositCreatorTxSig  String?               @map("escrow_deposit_creator_tx_sig")
  escrowDepositOpponentTxSig String?               @map("escrow_deposit_opponent_tx_sig")
  escrowCreatorAttemptedAt   DateTime?             @map("escrow_creator_attempted_at")
  escrowOpponentAttemptedAt  DateTime?             @map("escrow_opponent_attempted_at")
  escrowLockedAt             DateTime?             @map("escrow_locked_at")
  escrowDepositLastError     String?               @map("escrow_deposit_last_error")
  escrowDepositRetryCount    Int                   @default(0) @map("escrow_deposit_retry_count")
  escrowDepositNextRetryAt   DateTime?             @map("escrow_deposit_next_retry_at")
  escrowDepositProcessingAt  DateTime?             @map("escrow_deposit_processing_at")
  escrowDepositProcessingBy  String?               @map("escrow_deposit_processing_by")

  idempotencyKey             String?               @unique @map("idempotency_key")
  acceptIdempotencyKey       String?               @unique @map("accept_idempotency_key")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  createdBy        User                         @relation("BetCreator", fields: [createdById], references: [id])
  opponent         User?                        @relation("BetOpponent", fields: [opponentUserId], references: [id])
  winner           User?                        @relation("BetWinner", fields: [winnerId], references: [id])
  pool             Pool?                        @relation(fields: [poolId], references: [id])
  match            Match?                       @relation(fields: [matchId], references: [id])
  participants     BetParticipant[]
  invite           BetInvite?
  evidence         BetEvidence[]
  stateTransitions BetStateTransition[]
  confirmations    BetParticipantConfirmation[]
  resultClaims     BetResultClaim[]
  disputes         Dispute[]
  externalRef      BetExternalRef?

  @@index([status], map: "idx_bets_status")
  @@index([createdById, createdAt], map: "idx_bets_creator_created")
  @@index([opponentUserId, createdAt], map: "idx_bets_opponent_created")
  @@index([poolId, status], map: "idx_bets_pool_status")
  @@index([matchId, status], map: "idx_bets_match_status")
  @@index([expiresAt], map: "idx_bets_expires_at")
  @@index([status, createdAt(sort: Desc)], map: "idx_bets_status_created_at")
  @@index([category, status, createdAt(sort: Desc)], map: "idx_bets_category_status_created_at")
  @@index([templateId], map: "idx_bets_template_id")
  @@index([ledgerStatus, ledgerNextRetryAt], map: "idx_bets_ledger_retry")
  @@index([status, ledgerStatus], map: "idx_bets_status_ledger")
  @@index([onChainPayoutStatus, payoutNextRetryAt], map: "idx_bets_payout_retry")
  @@index([escrowDepositStatus, escrowDepositNextRetryAt], map: "idx_bets_escrow_deposit_retry")
  @@map("bets")
}

model BetParticipant {
  id           String    @id @default(uuid())
  betId        String    @map("bet_id")
  userId       String    @map("user_id")
  side         String
  hasConfirmed Boolean   @default(false) @map("has_confirmed")
  confirmedAt  DateTime? @map("confirmed_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  bet  Bet  @relation(fields: [betId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@unique([betId, side], map: "uq_bet_participants_bet_side")
  @@unique([betId, userId], map: "uq_bet_participants_bet_user")
  @@index([userId, createdAt], map: "idx_bet_participants_user_created")
  @@map("bet_participants")
}

model BetInvite {
  id        String    @id @default(uuid())
  betId     String    @unique @map("bet_id")
  tokenHash String    @unique @map("token_hash")
  createdAt DateTime  @default(now()) @map("created_at")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  usedById  String?   @map("used_by_id")

  bet    Bet   @relation(fields: [betId], references: [id], onDelete: Cascade)
  usedBy User? @relation(fields: [usedById], references: [id])

  @@index([expiresAt], map: "idx_bet_invites_expires")
  @@map("bet_invites")
}

model BetEvidence {
  id           String       @id @default(uuid())
  betId        String       @map("bet_id")
  uploadedById String       @map("uploaded_by_id")
  type         EvidenceType
  fileUrl      String?      @map("file_url")
  mimeType     String?      @map("mime_type")
  contentHash  String       @map("content_hash")
  description  String?
  createdAt    DateTime     @default(now()) @map("created_at")

  bet        Bet  @relation(fields: [betId], references: [id], onDelete: Cascade)
  uploadedBy User @relation(fields: [uploadedById], references: [id])

  @@unique([betId, contentHash], map: "uq_bet_evidence_bet_hash")
  @@index([uploadedById, createdAt], map: "idx_bet_evidence_user_created")
  @@map("bet_evidence")
}

model BetStateTransition {
  id         String    @id @default(uuid())
  betId      String    @map("bet_id")
  fromStatus BetStatus @map("from_status")
  toStatus   BetStatus @map("to_status")
  actorId    String?   @map("actor_id")
  actorType  String    @map("actor_type")
  metadata   Json?
  createdAt  DateTime  @default(now()) @map("created_at")

  bet   Bet   @relation(fields: [betId], references: [id], onDelete: Cascade)
  actor User? @relation(fields: [actorId], references: [id])

  @@index([betId, createdAt], map: "idx_bet_state_transitions_bet_created")
  @@index([actorId, createdAt], map: "idx_bet_state_transitions_actor_created")
  @@map("bet_state_transitions")
}

model BetParticipantConfirmation {
  id              String               @id @default(uuid())
  betId           String               @map("bet_id")
  userId          String               @map("user_id")
  decision        ConfirmationDecision
  claimedWinnerId String?              @map("claimed_winner_id")
  createdAt       DateTime             @default(now()) @map("created_at")

  bet           Bet   @relation(fields: [betId], references: [id], onDelete: Cascade)
  user          User  @relation("ConfirmationActor", fields: [userId], references: [id])
  claimedWinner User? @relation("ConfirmationClaimedWinner", fields: [claimedWinnerId], references: [id])

  @@index([betId, createdAt], map: "idx_bet_confirmations_bet_created")
  @@index([userId, createdAt], map: "idx_bet_confirmations_user_created")
  @@map("bet_participant_confirmations")
}

model BetResultClaim {
  id              String   @id @default(uuid())
  betId           String   @map("bet_id")
  claimedById     String   @map("claimed_by_id")
  claimedWinnerId String?  @map("claimed_winner_id")
  note            String?
  createdAt       DateTime @default(now()) @map("created_at")

  bet           Bet   @relation(fields: [betId], references: [id], onDelete: Cascade)
  claimedBy     User  @relation("ResultClaimActor", fields: [claimedById], references: [id])
  claimedWinner User? @relation("ResultClaimWinner", fields: [claimedWinnerId], references: [id])

  @@unique([betId, claimedById], map: "uq_bet_result_claims_bet_user")
  @@index([betId, createdAt], map: "idx_bet_result_claims_bet_created")
  @@map("bet_result_claims")
}

model Pool {
  id               String           @id @default(uuid())
  createdById      String           @map("created_by_id")
  title            String
  description      String?
  status           PoolStatus       @default(DRAFT)
  tournamentFormat TournamentFormat @default(SIMPLE) @map("tournament_format")
  bettingClosesAt  DateTime         @map("betting_closes_at")
  bracketLockedAt  DateTime?        @map("bracket_locked_at")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  createdBy    User              @relation("PoolCreator", fields: [createdById], references: [id])
  matches      Match[]
  bets         Bet[]
  participants PoolParticipant[]

  @@index([status], map: "idx_pools_status")
  @@index([createdById, createdAt], map: "idx_pools_creator_created")
  @@index([tournamentFormat], map: "idx_pools_tournament_format")
  @@map("pools")
}

model PoolParticipant {
  id          String   @id @default(uuid())
  poolId      String   @map("pool_id")
  displayName String   @map("display_name")
  seed        Int
  createdAt   DateTime @default(now()) @map("created_at")

  pool       Pool    @relation(fields: [poolId], references: [id], onDelete: Cascade)
  matchesAsA Match[] @relation("MatchParticipantA")
  matchesAsB Match[] @relation("MatchParticipantB")
  matchesWon Match[] @relation("MatchWinner")

  @@unique([poolId, seed], map: "uq_pool_participants_pool_seed")
  @@index([poolId], map: "idx_pool_participants_pool")
  @@map("pool_participants")
}

model Match {
  id                  String       @id @default(uuid())
  poolId              String       @map("pool_id")
  title               String
  description         String?
  eventTime           DateTime?    @map("event_time")
  status              MatchStatus  @default(SCHEDULED)
  winnerSide          String?      @map("winner_side")
  participantAId      String?      @map("participant_a_id")
  participantBId      String?      @map("participant_b_id")
  winnerParticipantId String?      @map("winner_participant_id")
  bracket             BracketSide?
  bracketSlot         String?      @map("bracket_slot")
  round               Int?
  nextMatchIdOnWin    String?      @map("next_match_id_on_win")
  nextMatchIdOnLoss   String?      @map("next_match_id_on_loss")
  submittedAt         DateTime?    @map("submitted_at")
  disputeWindowEndsAt DateTime?    @map("dispute_window_ends_at")
  settledAt           DateTime?    @map("settled_at")
  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @updatedAt @map("updated_at")

  pool              Pool             @relation(fields: [poolId], references: [id], onDelete: Cascade)
  bets              Bet[]
  evidence          MatchEvidence[]
  participantA      PoolParticipant? @relation("MatchParticipantA", fields: [participantAId], references: [id], onDelete: SetNull)
  participantB      PoolParticipant? @relation("MatchParticipantB", fields: [participantBId], references: [id], onDelete: SetNull)
  winnerParticipant PoolParticipant? @relation("MatchWinner", fields: [winnerParticipantId], references: [id], onDelete: SetNull)
  nextMatchOnWin    Match?           @relation("MatchAdvanceWin", fields: [nextMatchIdOnWin], references: [id], onDelete: SetNull)
  advancedToOnWin   Match[]          @relation("MatchAdvanceWin")
  nextMatchOnLoss   Match?           @relation("MatchAdvanceLoss", fields: [nextMatchIdOnLoss], references: [id], onDelete: SetNull)
  advancedToOnLoss  Match[]          @relation("MatchAdvanceLoss")

  @@index([poolId, status], map: "idx_matches_pool_status")
  @@index([eventTime], map: "idx_matches_event_time")
  @@index([participantAId], map: "idx_matches_participant_a")
  @@index([participantBId], map: "idx_matches_participant_b")
  @@index([poolId, round, bracket], map: "idx_matches_pool_round_bracket")
  @@map("matches")
}

model MatchEvidence {
  id           String       @id @default(uuid())
  matchId      String       @map("match_id")
  uploadedById String       @map("uploaded_by_id")
  type         EvidenceType
  fileUrl      String?      @map("file_url")
  mimeType     String?      @map("mime_type")
  contentHash  String       @map("content_hash")
  description  String?
  createdAt    DateTime     @default(now()) @map("created_at")

  match      Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  uploadedBy User  @relation(fields: [uploadedById], references: [id])

  @@unique([matchId, contentHash], map: "uq_match_evidence_match_hash")
  @@index([uploadedById, createdAt], map: "idx_match_evidence_user_created")
  @@map("match_evidence")
}

model Dispute {
  id                String          @id @default(uuid())
  betId             String          @map("bet_id")
  openedById        String          @map("opened_by_id")
  reason            String
  depositLedgerTxId String?         @map("deposit_ledger_tx_id")
  status            DisputeStatus   @default(OPEN)
  outcome           DisputeOutcome?
  resolvedById      String?         @map("resolved_by_id")
  resolvedAt        DateTime?       @map("resolved_at")
  adminNotes        String?         @map("admin_notes")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  bet        Bet   @relation(fields: [betId], references: [id], onDelete: Cascade)
  openedBy   User  @relation("DisputeOpener", fields: [openedById], references: [id])
  resolvedBy User? @relation("DisputeResolver", fields: [resolvedById], references: [id])

  @@index([betId, status], map: "idx_disputes_bet_status")
  @@index([openedById, createdAt], map: "idx_disputes_opener_created")
  @@index([status, createdAt], map: "idx_disputes_status_created")
  @@map("disputes")
}

model UserReputation {
  id             String         @id @default(uuid())
  userId         String         @unique @map("user_id")
  score          Int            @default(500)
  disputesOpened Int            @default(0) @map("disputes_opened")
  disputesWon    Int            @default(0) @map("disputes_won")
  disputesLost   Int            @default(0) @map("disputes_lost")
  tier           ReputationTier @default(NORMAL)
  lastUpdatedAt  DateTime       @default(now()) @map("last_updated_at")

  user User @relation(fields: [userId], references: [id])

  @@index([tier], map: "idx_user_reputation_tier")
  @@index([score], map: "idx_user_reputation_score")
  @@map("user_reputations")
}

model ReputationEvent {
  id             String              @id @default(uuid())
  userId         String              @map("user_id")
  eventType      ReputationEventType @map("event_type")
  scoreDelta     Int                 @map("score_delta")
  scoreAfter     Int                 @map("score_after")
  tierBefore     ReputationTier      @map("tier_before")
  tierAfter      ReputationTier      @map("tier_after")
  refType        String?             @map("ref_type")
  refId          String?             @map("ref_id")
  metadata       Json?
  idempotencyKey String              @unique @map("idempotency_key")
  createdAt      DateTime            @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt], map: "idx_reputation_events_user")
  @@index([eventType], map: "idx_reputation_events_type")
  @@index([refType, refId], map: "idx_reputation_events_ref")
  @@map("reputation_events")
}

enum ReputationEventType {
  BET_SETTLED_CLEAN
  BET_SETTLED_AUTO
  DISPUTE_OPENED
  DISPUTE_WON
  DISPUTE_LOST
  DISPUTE_VOID
  FORCE_CANCELLED
  BET_EXPIRED
  ADMIN_PENALTY
  ADMIN_BONUS
}

model BetTemplate {
  id                    String           @id @default(uuid())
  slug                  String           @unique
  name                  String
  category              String
  description           String?
  settlementType        SettlementType   @map("settlement_type")
  settlementMethod      SettlementMethod @default(PLATFORM_PROOF) @map("settlement_method")
  outcomeType           String           @map("outcome_type")
  fieldsSchema          Json             @map("fields_schema")
  allowedSources        Json             @map("allowed_sources")
  resolutionRule        String           @map("resolution_rule")
  supportsAutoResolve   Boolean          @default(false) @map("supports_auto_resolve")
  requiresOfficialEvent Boolean          @default(false) @map("requires_official_event")

  // Zentrix improvements over Wager v2
  isActive    Boolean   @default(true) @map("is_active")
  version     Int       @default(1)
  createdById String?   @map("created_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  @@index([slug], map: "idx_bet_templates_slug")
  @@index([category, isActive, deletedAt], map: "idx_bet_templates_category_active")
  @@index([settlementType], map: "idx_bet_templates_settlement_type")
  @@index([deletedAt, isActive], map: "idx_bet_templates_soft_delete")
  @@map("bet_templates")
}

// ── P30: External event references ──────────────────────────────────
//
// Sparse 1:1 met Bet. Alleen bets met settlementMethod=OFFICIAL_RESULT
// hebben een ref. Cron-worker queryt op (provider, eventEndsAt, processedAt).
//
// Provider naming convention:
//   "espn"          → ESPN public endpoints
//   "thesportsdb"   → TheSportsDB free tier
//   "football-data" → Football-data.org free tier
//
// Status fields:
//   processedAt   → laatste cron processing attempt
//   resolvedAt    → succesvol opgelost (winnerSide bekend)
//   failedAt      → permanent failed (max retries reached, escalates manual)
//   retryCount    → hoeveelheid cron pogingen
//
// Index strategy:
//   (provider, eventEndsAt) → cron's primary query
//   (eventEndsAt)            → fallback alle-providers scan
//   (betId)                  → lookup from bet page (already @unique)
model BetExternalRef {
  id            String   @id @default(uuid())
  betId         String   @unique @map("bet_id")
  provider      String
  eventId       String   @map("event_id")
  league        String
  sport         String
  eventStartsAt DateTime @map("event_starts_at")
  eventEndsAt   DateTime @map("event_ends_at")

  // Processing state
  processedAt   DateTime? @map("processed_at")
  resolvedAt    DateTime? @map("resolved_at")
  failedAt      DateTime? @map("failed_at")
  retryCount    Int       @default(0) @map("retry_count")
  lastError     String?   @map("last_error")
  nextRetryAt   DateTime? @map("next_retry_at")
  lastAttemptAt DateTime? @map("last_attempt_at")

  // Resolution outcome (cached zodat we backend kunnen reconstrueren)
  resolvedWinnerSide String? @map("resolved_winner_side")
  resolvedPayload    Json?   @map("resolved_payload")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  bet Bet @relation(fields: [betId], references: [id], onDelete: Cascade)

  @@index([provider, eventEndsAt], map: "idx_bet_external_refs_provider_ends")
  @@index([eventEndsAt], map: "idx_bet_external_refs_ends")
  @@index([processedAt], map: "idx_bet_external_refs_processed")
  @@index([nextRetryAt, processedAt], map: "idx_bet_external_refs_next_retry")
  @@map("bet_external_refs")
}

// ── Provider health (circuit breaker state) ──────────────────────────
//
// Per provider: window van laatste N requests + failure rate.
// Cron checkt voor elke fetch of provider OPEN/HALF_OPEN/CLOSED.
// State is shared across serverless invocations (in-memory zou niet werken).
//
// State transitions:
//   CLOSED          → normaal verkeer
//   OPEN            → geen requests, cooldown actief
//   HALF_OPEN       → één probe request toegestaan
model ExternalProviderHealth {
  provider      String    @id
  state         String    @default("CLOSED")
  failureCount  Int       @default(0) @map("failure_count")
  successCount  Int       @default(0) @map("success_count")
  totalRequests Int       @default(0) @map("total_requests")
  lastFailureAt DateTime? @map("last_failure_at")
  lastSuccessAt DateTime? @map("last_success_at")
  cooldownUntil DateTime? @map("cooldown_until")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@map("external_provider_health")
}
