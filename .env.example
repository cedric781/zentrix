# Database
DATABASE_URL="postgresql://user:pass@host:5432/db?schema=public"
DIRECT_URL="postgresql://user:pass@host:5432/db?schema=public"

# Privy (prompt 03)
PRIVY_APP_ID=""
PRIVY_APP_SECRET=""
NEXT_PUBLIC_PRIVY_APP_ID=""
# P61 — TEE wallet delegation. Copy from Privy dashboard → Server signers.
# Public (NEXT_PUBLIC_) because the client passes it to addSigners(); it's
# an identifier, not a secret.
NEXT_PUBLIC_PRIVY_SIGNER_ID=""
# Optional override for the 30s authorize timeout race.
NEXT_PUBLIC_PRIVY_AUTHORIZE_TIMEOUT_MS="30000"
# P61b — server-side authorization key for the same signer that
# NEXT_PUBLIC_PRIVY_SIGNER_ID references. Format: wallet-auth:<base64>.
# Copy from Privy dashboard → Server signers → Authorization key.
# Required for withdrawals; without it Privy rejects signAndSendTransaction
# with "Missing privy-authorization-signature header".
PRIVY_AUTHORIZATION_PRIVATE_KEY=""

# Solana (prompt 03+)
HELIUS_RPC_URL=""
USDC_MINT_ADDRESS="EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v"

# Kill switches (R8) — set to "true" to disable
DEPOSITS_DISABLED="false"
WITHDRAWALS_DISABLED="false"

# ── P30 Auto-resolve ────────────────────────────────────────────────
# CRON_SECRET reeds gebruikt voor andere crons (P15) — geen extra var nodig
# voor resolve-bets cron.

# TheSportsDB API key (free tier default "3", upgrade via dashboard voor
# hogere rate limits). Optioneel — adapter gebruikt "3" als unset.
THESPORTSDB_API_KEY=""

# ESPN gebruikt geen API key (public endpoints).

# Football-data.org niet geïmplementeerd in MVP (placeholder in router).
# FOOTBALL_DATA_API_KEY=""